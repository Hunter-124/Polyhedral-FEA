solid thin_plate
  facet normal 0 0 -1
    outer loop
      vertex 0 0 0
      vertex 2 1 0
      vertex 2 0 0
    endloop
  endfacet
  facet normal 0 0 -1
    outer loop
      vertex 0 0 0
      vertex 0 1 0
      vertex 2 1 0
    endloop
  endfacet
  facet normal 0 0 1
    outer loop
      vertex 0 0 0.05
      vertex 2 0 0.05
      vertex 2 1 0.05
    endloop
  endfacet
  facet normal 0 0 1
    outer loop
      vertex 0 0 0.05
      vertex 2 1 0.05
      vertex 0 1 0.05
    endloop
  endfacet
  facet normal 0 -1 0
    outer loop
      vertex 0 0 0
      vertex 2 0 0
      vertex 2 0 0.05
    endloop
  endfacet
  facet normal 0 -1 0
    outer loop
      vertex 0 0 0
      vertex 2 0 0.05
      vertex 0 0 0.05
    endloop
  endfacet
  facet normal 0 1 0
    outer loop
      vertex 2 1 0
      vertex 0 1 0
      vertex 0 1 0.05
    endloop
  endfacet
  facet normal 0 1 0
    outer loop
      vertex 2 1 0
      vertex 0 1 0.05
      vertex 2 1 0.05
    endloop
  endfacet
  facet normal -1 0 0
    outer loop
      vertex 0 0 0
      vertex 0 0 0.05
      vertex 0 1 0.05
    endloop
  endfacet
  facet normal -1 0 0
    outer loop
      vertex 0 0 0
      vertex 0 1 0.05
      vertex 0 1 0
    endloop
  endfacet
  facet normal 1 0 0
    outer loop
      vertex 2 0 0
